# SwarmOps Backend — copy to backend/.env for local development

# GitHub (repo scope for issues + PRs)
GITHUB_TOKEN=

# LLM: comma-separated priority, e.g. openrouter,groq,gemini,azure
LLM_PROVIDER=gemini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o

AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o

DATABASE_URL=sqlite:///swarmops.db
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1
