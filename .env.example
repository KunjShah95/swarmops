# =============================================================================
# SwarmOps — Environment Configuration
# =============================================================================
# Copy this file to .env in the PROJECT ROOT (both docker-compose and local dev use this)
#   cp .env.example .env
#
# Required: GITHUB_TOKEN + at least one LLM provider key for real functionality
# Without these, the app falls back to simulated/mock data.
# =============================================================================

# --- GitHub (REQUIRED for real PRs) ---
# Personal Access Token (classic) with "repo" scope for private repos,
# or "public_repo" + "write:repo_hook" for public repos.
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=

# --- LLM Provider (at least ONE required for real AI output) ---
# Priority list: tries providers in comma-separated order, falls through on failure.
# Supported: openrouter, groq, gemini, azure, bedrock
LLM_PROVIDER=gemini

# --- Google Gemini (free tier, great for hackathons) ---
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Groq (fast inference, generous free tier) ---
# Sign up: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile

# --- OpenRouter (access to many models) ---
# Sign up: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o

# --- Azure OpenAI (optional -- Microsoft hackathon) ---
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_KEY=
# AZURE_OPENAI_DEPLOYMENT=gpt-4o

# --- AWS Bedrock (optional) ---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# --- Runtime (optional -- defaults below are fine for local dev) ---
DATABASE_URL=sqlite:///swarmops.db
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173
