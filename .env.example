# SwarmOps — copy to .env in project root (used by docker-compose)
# For local dev without Docker, copy relevant vars to backend/.env

# --- GitHub (required for real PRs; optional for demo fallback) ---
GITHUB_TOKEN=

# --- LLM provider (pick one or set priority list) ---
# Examples: gemini | groq | openrouter | azure | openrouter,groq,gemini
LLM_PROVIDER=gemini

# Google Gemini (free tier friendly for hackathons)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o

# Azure OpenAI (Microsoft hackathon)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# --- Runtime ---
DATABASE_URL=sqlite:////data/swarmops.db
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost
CORS_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:5173
